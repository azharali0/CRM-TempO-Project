# ═══════════════════════════════════════════════════
#   CRM TempO Project — Environment Variables
#   Copy this file:  cp .env.example .env
#   Then fill in your values below.
# ═══════════════════════════════════════════════════

# ── Database ──────────────────────────────────────
DB_URL=jdbc:postgresql://db:5432/crm_db
DB_USERNAME=crm_user
DB_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=crm_db

# ── Redis ─────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT (MUST be at least 32 characters) ──────────
JWT_SECRET=change_this_to_a_random_string_at_least_32_characters_long

# ── Server ────────────────────────────────────────
SERVER_PORT=8080

# ── Mail (optional — app works without SMTP) ──────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ── File Uploads ──────────────────────────────────
FILE_UPLOAD_DIR=/var/crm/uploads
