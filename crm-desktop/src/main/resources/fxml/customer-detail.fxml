<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" styleClass="screen-container"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.crm.desktop.controller.CustomerDetailController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Customer Details" styleClass="screen-title"/>
    <ProgressIndicator fx:id="loadingSpinner" maxWidth="30" maxHeight="30"/>

    <GridPane hgap="15" vgap="10">
        <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"
               styleClass="detail-label"/>
        <Label fx:id="nameLabel" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1"
               styleClass="detail-label"/>
        <Label fx:id="emailLabel" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Phone:" GridPane.columnIndex="0" GridPane.rowIndex="2"
               styleClass="detail-label"/>
        <Label fx:id="phoneLabel" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Company:" GridPane.columnIndex="0" GridPane.rowIndex="3"
               styleClass="detail-label"/>
        <Label fx:id="companyLabel" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="City:" GridPane.columnIndex="0" GridPane.rowIndex="4"
               styleClass="detail-label"/>
        <Label fx:id="cityLabel" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Status:" GridPane.columnIndex="0" GridPane.rowIndex="5"
               styleClass="detail-label"/>
        <Label fx:id="statusLabel" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

        <Label text="Assigned To:" GridPane.columnIndex="0" GridPane.rowIndex="6"
               styleClass="detail-label"/>
        <Label fx:id="assignedToLabel" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
    </GridPane>

    <Separator/>

    <Label text="Interaction Timeline" styleClass="section-title"/>
    <ListView fx:id="interactionList" VBox.vgrow="ALWAYS" prefHeight="200"/>
</VBox>
