<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" styleClass="screen-container"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.crm.desktop.controller.TaskListController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Tasks" styleClass="screen-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Status:"/>
        <ComboBox fx:id="statusFilter" onAction="#handleFilter"/>
        <Button text="✓ Mark Complete" onAction="#handleComplete" styleClass="primary-button"/>
    </HBox>

    <ProgressIndicator fx:id="loadingSpinner" maxWidth="30" maxHeight="30"/>

    <TableView fx:id="taskTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="220"/>
            <TableColumn fx:id="dueDateColumn" text="Due Date" prefWidth="150"/>
            <TableColumn fx:id="priorityColumn" text="Priority" prefWidth="100"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
            <TableColumn fx:id="assignedToColumn" text="Assigned To" prefWidth="150"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER" spacing="10">
        <Button text="← Previous" onAction="#handlePrevPage" styleClass="secondary-button"/>
        <Label fx:id="pageLabel" text="Page 1 of 1"/>
        <Button text="Next →" onAction="#handleNextPage" styleClass="secondary-button"/>
    </HBox>
</VBox>
