<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" styleClass="screen-container"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.crm.desktop.controller.LeadPipelineController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Lead Pipeline" styleClass="screen-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="⟳ Refresh" onAction="#handleRefresh" styleClass="secondary-button"/>
    </HBox>

    <ProgressIndicator fx:id="loadingSpinner" maxWidth="30" maxHeight="30"/>

    <ScrollPane fitToHeight="true" VBox.vgrow="ALWAYS">
        <HBox fx:id="kanbanBoard" spacing="15">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
        </HBox>
    </ScrollPane>
</VBox>
