<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" styleClass="screen-container"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.crm.desktop.controller.CustomerFormController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Customer Form" styleClass="screen-title"/>
    <ProgressIndicator fx:id="loadingSpinner" maxWidth="30" maxHeight="30"/>

    <GridPane hgap="15" vgap="10" maxWidth="500">
        <Label text="Name *" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="nameField" promptText="Customer name"
                   GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="300"/>

        <Label text="Email" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="emailField" promptText="email@company.com"
                   GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="300"/>

        <Label text="Phone" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="phoneField" promptText="0300-1234567"
                   GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="300"/>

        <Label text="Company" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="companyField" promptText="Company name"
                   GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="300"/>

        <Label text="Address" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="addressField" promptText="Street address"
                   GridPane.columnIndex="1" GridPane.rowIndex="4" prefWidth="300"/>

        <Label text="City" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <TextField fx:id="cityField" promptText="City"
                   GridPane.columnIndex="1" GridPane.rowIndex="5" prefWidth="300"/>
    </GridPane>

    <Button fx:id="saveButton" text="Save Customer" onAction="#handleSave"
            styleClass="primary-button" prefWidth="200" prefHeight="35"/>
</VBox>
