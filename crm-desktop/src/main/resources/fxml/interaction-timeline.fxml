<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" styleClass="screen-container"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.crm.desktop.controller.InteractionTimelineController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Interaction Timeline" styleClass="screen-title"/>

    <!-- Filter bar -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Type:"/>
        <ComboBox fx:id="typeFilter" onAction="#handleFilter"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <ProgressIndicator fx:id="loadingSpinner" maxWidth="30" maxHeight="30"/>

    <!-- Timeline table -->
    <TableView fx:id="timelineTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="150"/>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="100"/>
            <TableColumn fx:id="subjectColumn" text="Subject" prefWidth="200"/>
            <TableColumn fx:id="notesColumn" text="Notes" prefWidth="250"/>
            <TableColumn fx:id="loggedByColumn" text="Logged By" prefWidth="120"/>
        </columns>
    </TableView>

    <!-- Pagination -->
    <HBox alignment="CENTER" spacing="10">
        <Button text="← Previous" onAction="#handlePrevPage" styleClass="secondary-button"/>
        <Label fx:id="pageLabel" text="Page 1 of 1"/>
        <Button text="Next →" onAction="#handleNextPage" styleClass="secondary-button"/>
    </HBox>

    <Separator/>

    <!-- Log new interaction -->
    <Label text="Log New Interaction" styleClass="section-title"/>
    <GridPane hgap="15" vgap="10" maxWidth="600">
        <Label text="Type" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <ComboBox fx:id="newTypeCombo"
                  GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="200"/>

        <Label text="Subject *" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="newSubjectField" promptText="Subject"
                   GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="300"/>

        <Label text="Notes" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextArea fx:id="newNotesArea" promptText="Notes..."
                  GridPane.columnIndex="1" GridPane.rowIndex="2"
                  prefWidth="300" prefHeight="60"/>

        <Label text="Duration (min)" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <Spinner fx:id="durationSpinner"
                 GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="120"/>
    </GridPane>

    <Button text="Log Interaction" onAction="#handleLogInteraction"
            styleClass="primary-button" prefWidth="200" prefHeight="35"/>
</VBox>
