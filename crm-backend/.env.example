# ===========================================
# CRM Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in values

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/crm_db
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here
POSTGRES_DB=crm_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# JWT Configuration (must be at least 256-bit / 32 chars)
JWT_SECRET=your_jwt_secret_key_must_be_at_least_256_bits_long_change_this

# Server Configuration
SERVER_PORT=8080

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Mail Configuration (optional — app works without SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# File Upload Directory
FILE_UPLOAD_DIR=./uploads
